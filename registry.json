{
	"$schema": "https://ui.shadcn.com/schema/registry.json",
	"name": "shadcn-video-editor",
	"homepage": "https://github.com/shreyvijayvargiya/shadcn-video-editor",
	"items": [
		{
			"name": "video-editor",
